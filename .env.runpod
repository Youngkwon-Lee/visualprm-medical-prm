# RunPod configuration for step-level PRM training

# Backend server
MODEL_PROVIDER=open_model
OPEN_MODEL_BASE_URL=http://127.0.0.1:8000/v1
OPEN_MODEL_API_KEY=EMPTY
OPEN_MODEL_GENERATE_MODEL=Qwen/Qwen2.5-VL-7B-Instruct
OPEN_MODEL_VERIFY_MODEL=Qwen/Qwen2.5-VL-7B-Instruct

# Local model server
QWEN_SERVE_MODEL_ID=Qwen/Qwen2.5-VL-7B-Instruct
QWEN_MODEL_ID=Qwen/Qwen2.5-7B-Instruct
QWEN_SERVER_HOST=0.0.0.0
QWEN_SERVER_PORT=8000
QWEN_MAX_NEW_TOKENS=512
QWEN_LOAD_IN_4BIT=0

# Training
TRAINING_TASK=prm_scorer
TRAIN_FILE=/workspace/data/train_standard.jsonl
VAL_FILE=/workspace/data/val_standard.jsonl
RATIONALE_TRAIN_FILE=/workspace/data/rationale_train_sample.jsonl
RATIONALE_VAL_FILE=/workspace/data/rationale_val_sample.jsonl
MODEL_NAME=Qwen/Qwen2.5-7B-Instruct
TRAINING_BATCH_SIZE=1
TRAINING_GRAD_ACCUM=8
TRAINING_EPOCHS=3
TRAINING_LEARNING_RATE=2e-5
TRAINING_WARMUP_RATIO=0.1
TRAINING_SAVE_INTERVAL=500
MAX_LENGTH=1536

# Paths
WORKSPACE_DIR=/workspace
DATA_DIR=/workspace/data
OUTPUT_DIR=/workspace/models
CACHE_DIR=/workspace/.cache

# Compute
CUDA_VISIBLE_DEVICES=0
MIXED_PRECISION=fp16
GRADIENT_CHECKPOINTING=1

# Logging
LOG_LEVEL=INFO
WANDB_DISABLED=1
