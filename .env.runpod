# RunPod A100 Configuration for Qwen3-VL-30B Local Training

# === Model Provider ===
MODEL_PROVIDER=open_model

# === Open Model Server Configuration ===
# RunPod 내부에서 실행할 때는 localhost:8000
# 외부 접근 시는 RunPod pod URL 사용
OPEN_MODEL_BASE_URL=http://localhost:8000
OPEN_MODEL_API_KEY=EMPTY
OPEN_MODEL_GENERATE_MODEL=Qwen/Qwen3-VL-30B-Instruct
OPEN_MODEL_VERIFY_MODEL=Qwen/Qwen3-VL-30B-Instruct

# === Qwen Server Configuration ===
QWEN_MODEL_ID=Qwen/Qwen3-VL-30B-Instruct
QWEN_SERVER_HOST=0.0.0.0
QWEN_SERVER_PORT=8000
QWEN_MAX_NEW_TOKENS=512
QWEN_LOAD_IN_4BIT=0

# === Training Configuration ===
TRAINING_BATCH_SIZE=16
TRAINING_EPOCHS=3
TRAINING_LEARNING_RATE=2e-5
TRAINING_WARMUP_RATIO=0.1
TRAINING_SAVE_INTERVAL=500

# === Data Configuration ===
DATASET_NAME=standard
# Options: mvp (36K), standard (162K), large (389K), mega (1170K)

# === Paths ===
WORKSPACE_DIR=/workspace
DATA_DIR=/workspace/data
OUTPUT_DIR=/workspace/models
CACHE_DIR=/workspace/.cache

# === Compute Configuration ===
CUDA_VISIBLE_DEVICES=0
MIXED_PRECISION=fp16
GRADIENT_CHECKPOINTING=1

# === Logging ===
LOG_LEVEL=INFO
WANDB_DISABLED=1
