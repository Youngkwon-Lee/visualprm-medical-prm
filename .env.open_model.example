# Open-model backend using an OpenAI-compatible local server
# Example servers: vLLM, LM Studio (OpenAI API mode), text-generation-webui compatible bridges
MODEL_PROVIDER=open_model

# Required: point this to your local inference server
OPEN_MODEL_BASE_URL=http://127.0.0.1:8000/v1

# Optional: many local servers ignore the API key, but the client requires one
OPEN_MODEL_API_KEY=EMPTY

# Optional model overrides
OPEN_MODEL_GENERATE_MODEL=Qwen/Qwen2.5-VL-7B-Instruct
OPEN_MODEL_VERIFY_MODEL=Qwen/Qwen2.5-VL-7B-Instruct
